MODEL_LABEL="DexJoCo (PhysiXel)"
MODEL_FAMILY=n1.6
# PhysiXel reads the action horizon from its modality config; the extra
# --action-horizon CLI flag is not passed (all experiments run in modality mode).
ACTION_HORIZON_MODE=modality
SLURM_REPO_VAR=PHYSIXEL_DIR
MLXP_REPO_DIR="${DDN_USER_HOME}/workspace/physixel"
TRAIN_BODY_SCRIPT=train_body.sh
EVAL_BODY_SCRIPT=eval_body_dexjoco.sh
TRAIN_WALLTIME=48:00:00
EVAL_WALLTIME=02:00:00
