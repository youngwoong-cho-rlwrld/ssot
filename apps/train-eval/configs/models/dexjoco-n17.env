MODEL_LABEL="DexJoCo (GR00T n1.7)"
MODEL_FAMILY=n1.7
# n1.7's single-dataset launcher (launch_finetune.py) has no --action-horizon
# flag: the chunk length is expressed through the modality config's action
# delta_indices. So the horizon is applied by rewriting the modality .py
# (mode=modality), exactly as dexjoco-n16. The multi-dataset launcher
# (launch_finetune_multi.py) does accept --action-horizon, but that path keys
# off TRAIN_DATA_YAML in the experiment config, not this mode.
ACTION_HORIZON_MODE=modality
SLURM_REPO_VAR=GROOT_N17_DIR
MLXP_REPO_DIR="${DDN_USER_HOME}/workspace/gr00t-n17"
TRAIN_BODY_SCRIPT=train_body.sh
EVAL_BODY_SCRIPT=eval_body_dexjoco.sh
TRAIN_WALLTIME=48:00:00
EVAL_WALLTIME=02:00:00
