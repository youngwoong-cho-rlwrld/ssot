MODEL_LABEL="DexJoCo (GAM)"
MODEL_FAMILY=gam
# GAM reads its action chunk size from gam_config.yaml; "none" disables the
# gr00t modality-config action-horizon rewrite (data_interface.py) and the CLI
# --action-horizon pass, neither of which apply to GAM.
ACTION_HORIZON_MODE=none
SLURM_REPO_VAR=GAM_DIR
MLXP_REPO_DIR="${DDN_USER_HOME}/workspace/gam"
TRAIN_BODY_SCRIPT=train_body_gam.sh
EVAL_BODY_SCRIPT=eval_body_dexjoco.sh
TRAIN_WALLTIME=48:00:00
EVAL_WALLTIME=02:00:00
