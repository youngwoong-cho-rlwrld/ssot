# SKT cluster env template.
# Configure user-specific values from the Settings page.
export CLUSTER=skt
export SSH_ALIAS=
export PARTITION=
export REPO_ROOT=
export GROOT_DIR=
export GROOT_N16_DIR=
# GR00T N1.7 checkout. Set to your per-user checkout path,
# e.g. /fsx/rlwrld/<user>/workspace/gr00t-n17
export GROOT_N17_DIR=
export PHYSIXEL_DIR=
export GAM_DIR=
export ISAAC_DIR=
export DATA_DIR=
export LOG_DIR=
export SBATCH_EXCLUDE=
export SLURM_EXCLUDE_NODES=
export LD_LIBRARY_PATH=

# DexJoCo (MuJoCo benchmark) eval harness - used by lib/eval_body_dexjoco.sh.
# DEXJOCO_DIR holds the eval client, task configs (configs/<family>/<task>.yaml),
# and the released pi0.5 checkpoints (checkpoints/pi05_dexjoco_ckpt/<task>).
# Experiment configs no longer pin DEXJOCO_GIT_COMMIT, so this MUST point at the
# canonical pinned checkout (dexjoco-canonical-6a6d1b2c) — that commit is the
# eval client's source of truth now.
export DEXJOCO_DIR=
export MICROMAMBA_BIN=
export MAMBA_ROOT_PREFIX=
export DEXJOCO_EVAL_ENV=
export DEXJOCO_OPENPI_ENV=
# Org unified checkpoints root. When set, training checkpoints/eval/logs are
# written here (per-user folder) instead of the legacy home path. SKT sets this
# via the Settings page (effective env); documented here for the template.
# export UNIFIED_EXPERIMENTS_DIR=/fsx/rlwrld-unified-checkpoints/<user>/experiments

