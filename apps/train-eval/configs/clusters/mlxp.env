# MLXP (Naver NCP k8s) cluster env template.
# Configure user-specific values from the Settings page. Variable names follow
# the slurm cluster convention (kakao.env/skt.env); MLXP-only concepts carry an
# MLXP_ prefix. Legacy TRAIN_EVAL_MLXP_* names are still accepted for back-compat.
export USER=
export MLXP_NAMESPACE=p-rlwrld
export MLXP_DDN_MOUNT=/data
export MLXP_DDN_PVC=ddn-rlwrld-shared
export MLXP_IMAGE=
export MLXP_IMAGE_PULL_SECRET=mlxp-registry
export MLXP_ZONE=private-h200-rlwrld-0

# Optional overrides. Leave blank/commented to take the derived default shown.
# HOME = {DDN_MOUNT}/{USER}; the dir defaults below hang off it.
# GPU node set and GPU type are derived (GPU-requesting pods; node-name
# inference), not configured. Only the per-node GPU count is a cluster constant.
# export MLXP_GPUS_PER_NODE=      # default: 8
# export MLXP_WANDB_SECRET=        # default: {USER}-wandb
# export MLXP_DATA_POD=            # default: {USER}-data-pod
# export MLXP_HOME=               # default: {DDN_MOUNT}/{USER}
# export DATA_DIR=                # default: {HOME}/datasets
# export UNIFIED_EXPERIMENTS_DIR= # default: {DDN_MOUNT}/rlwrld-unified-checkpoints/{USER}/experiments
# export HF_HOME=                 # default: {HOME}/.cache/huggingface
# export WORKSPACE_DIR=           # default: {HOME}/workspace
# export ISAAC_DIR=               # default: {HOME}/workspace/rlwrld_isaac

# DexJoCo (MuJoCo benchmark) eval deps on the DDN. Leave blank to use the
# per-user defaults that mirror the kakao layout.
# export DEXJOCO_DIR=             # default: {HOME}/workspace/dexjoco
# export MICROMAMBA_BIN=          # default: {HOME}/bin/micromamba
# export MAMBA_ROOT_PREFIX=       # default: {HOME}/micromamba
# export DEXJOCO_EVAL_ENV=        # default: dexjoco
# export DEXJOCO_OPENPI_ENV=      # default: openpi
