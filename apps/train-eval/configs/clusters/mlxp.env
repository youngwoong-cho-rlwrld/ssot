# per-user defaults ($HOME/workspace/dexjoco, $HOME/bin/micromamba,
# $HOME/micromamba, envs dexjoco/openpi) that mirror the kakao layout.
export TRAIN_EVAL_MLXP_DEXJOCO_DIR=
export TRAIN_EVAL_MLXP_MICROMAMBA_BIN=
export TRAIN_EVAL_MLXP_MAMBA_ROOT_PREFIX=
export TRAIN_EVAL_MLXP_DEXJOCO_EVAL_ENV=
