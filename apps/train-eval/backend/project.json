{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "name": "@ssot/train-eval-api",
  "projectType": "application",
  "targets": {
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv sync",
        "cwd": "apps/train-eval/backend"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run uvicorn app.main:app --host ${TRAIN_EVAL_API_HOST:-127.0.0.1} --port ${TRAIN_EVAL_API_PORT:-8000} --reload",
        "cwd": "apps/train-eval/backend"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run uvicorn app.main:app --host ${TRAIN_EVAL_API_HOST:-127.0.0.1} --port ${TRAIN_EVAL_API_PORT:-8000}",
        "cwd": "apps/train-eval/backend"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run python -m unittest discover -s tests -v",
        "cwd": "apps/train-eval/backend"
      }
    }
  }
}
