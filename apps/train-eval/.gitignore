# Python bytecode (backend, scripts, anywhere)
__pycache__/
*.pyc

# Backend
backend/.venv/
backend/*.db
backend/.env

# Frontend
frontend/node_modules/
frontend/.next/
frontend/.env.local
frontend/.env

# Variant configs are per-user / per-experiment; only the _sample/ template
# ships in git so newcomers have a starting reference.
configs/experiments/*
!configs/experiments/_sample/
!configs/experiments/_sample/**
# DexJoCo rollout configs are a cross-repository runtime contract. Keep their
# shell defaults—and GAM's model-facing YAML—reviewable and immutable in Git.
!configs/experiments/dexjoco_*/
configs/experiments/dexjoco_*/*
!configs/experiments/dexjoco_*/config.sh
!configs/experiments/dexjoco_gam_*/gam_config.yaml
configs/experiments/*/.versions/
configs/experiments/*/.versions/**

# Local scratch
.DS_Store
*.bak
*.bak.*

# OMC tooling state (oh-my-claudecode session/state files)
.omc/

# wandb local run cache (e.g. from GAM backfill run in backend cwd)
backend/wandb/
