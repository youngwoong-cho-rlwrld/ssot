# Python bytecode (backend, scripts, anywhere)
__pycache__/
*.pyc

# Backend
backend/.venv/
backend/*.db
backend/.env

# Frontend
frontend/node_modules/
frontend/.next/
frontend/.env.local
frontend/.env

# SSOT tracks the full experiment list (configs + model-facing sidecars);
# only the per-run .versions snapshots stay local.
configs/experiments/*/.versions/
configs/experiments/*/.versions/**

# Local scratch
.DS_Store
*.bak
*.bak.*

# OMC tooling state (oh-my-claudecode session/state files)
.omc/

# wandb local run cache (e.g. from GAM backfill run in backend cwd)
backend/wandb/
