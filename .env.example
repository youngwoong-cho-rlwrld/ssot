# SSOT configuration. Copy to .env and adjust; every value has a working
# default for local single-machine use. Nx injects this file into all tasks,
# and the gateway loads it directly as a fallback.

# --- gateway (the single entrypoint) --------------------------------------
# SSOT_HOST=0.0.0.0
# SSOT_PORT=4000
# SSOT_ENV=production            # "production" serves Vite apps from dist/
# SSOT_CONFIG=/path/to/ssot.config.json   # optional JSON override for the app registry

# Where the gateway finds each app (defaults = historical standalone ports).
# SSOT_TRAIN_EVAL_ORIGIN=http://127.0.0.1:3000
# SSOT_TRAIN_EVAL_API_ORIGIN=http://127.0.0.1:8000   # /train-eval/api/* is proxied here by the gateway
# SSOT_RESULTS_ORIGIN=http://127.0.0.1:3001
# SSOT_URDF_DEV_ORIGIN=http://127.0.0.1:5173
# SSOT_SESSIONS_WEB_DEV_ORIGIN=http://127.0.0.1:5174
# SSOT_SESSIONS_API_ORIGIN=http://127.0.0.1:8787
# SSOT_OPENCLAW_WEB_DEV_ORIGIN=http://127.0.0.1:5175
# SSOT_OPENCLAW_API_ORIGIN=http://127.0.0.1:8790   # /openclaw/api/* is proxied here by the gateway
# SSOT_MODEL_DIAGRAM_WEB_DEV_ORIGIN=http://127.0.0.1:5176
# SSOT_MODEL_DIAGRAM_API_ORIGIN=http://127.0.0.1:8791   # /model-diagram/api/* is proxied here by the gateway

# Mount points on the gateway origin.
# SSOT_TRAIN_EVAL_BASE_PATH=/train-eval
# SSOT_RESULTS_BASE_PATH=/results
# SSOT_URDF_BASE_PATH=/urdf
# SSOT_SESSIONS_BASE_PATH=/sessions
# SSOT_OPENCLAW_BASE_PATH=/openclaw
# SSOT_MODEL_DIAGRAM_BASE_PATH=/model-diagram

# Enable/disable individual apps on the portal.
# SSOT_TRAIN_EVAL_ENABLED=true
# SSOT_RESULTS_ENABLED=true
# SSOT_URDF_ENABLED=true
# SSOT_SESSIONS_ENABLED=true
# SSOT_OPENCLAW_ENABLED=true
# SSOT_MODEL_DIAGRAM_ENABLED=true

# Static build locations (production mode).
# SSOT_URDF_DIST=apps/urdf-viewer/dist
# SSOT_SESSIONS_DIST=apps/session-viewer/frontend/dist
# SSOT_OPENCLAW_DIST=apps/openclaw/frontend/dist
# SSOT_MODEL_DIAGRAM_DIST=apps/model-diagram/frontend/dist

# --- shared ----------------------------------------------------------------
# Single SQLite database for anything SSOT persists (session-viewer board
# state, users, sessions, and per-user settings). Defaults to ~/.ssot/ssot.db.
# SSOT_DATA_DIR=~/.ssot

# --- auth / user management ------------------------------------------------
# Sign-in is no-password: /auth/login takes an email or an explicitly allowed
# local account ID. Whoever enters an allowed identifier is signed in as that
# user. Identity is trust-based (there is no password or SSO), so run the
# gateway only on a trusted network.
#
# Comma-separated list of email domains allowed to sign in (empty = allow any).
# SSOT_ALLOWED_EMAIL_DOMAINS=
# Comma-separated local account IDs allowed to sign in (empty = none).
# SSOT_ALLOWED_USER_IDS=admin
# Public origin browsers reach the gateway on. The session cookie is marked
# Secure when this is https.
# SSOT_PUBLIC_URL=http://localhost:4000
# Session lifetime in days (default 30).
# SSOT_SESSION_TTL_DAYS=30

# --- train-eval ------------------------------------------------------------
# TRAIN_EVAL_WEB_PORT=3000
# TRAIN_EVAL_API_HOST=127.0.0.1
# TRAIN_EVAL_API_PORT=8000
# BACKEND_INTERNAL_ORIGIN=http://127.0.0.1:8000
# TRAIN_EVAL_CORS_ORIGINS=http://localhost:3000
# TRAIN_EVAL_REMOTE_PATH_PREPEND=        # PATH prefix for remote slurm commands (e.g. /opt/slurm/bin)
# NEXT_PUBLIC_RESULTS_VIEWER_URL=/results

# --- results-sheet ---------------------------------------------------------
# RESULTS_SHEET_HOST=127.0.0.1           # keep loopback-only; gateway supplies trusted identity
# RESULTS_SHEET_PORT=3001
# RESULTS_API_BASE=http://127.0.0.1:8000
# OPENCLAW_API_BASE=http://127.0.0.1:8790  # server-side Results chat transport
# OPENCLAW_CHAT_TIMEOUT_MS=140000
# RESULTS_CONFIGS_ROOT=                  # defaults to apps/train-eval/configs/experiments
# RESULTS_ALLOWED_DEV_ORIGINS=           # comma-separated LAN IPs for next dev

# --- urdf-viewer -----------------------------------------------------------
# URDF_DEV_PORT=5173

# --- session-viewer --------------------------------------------------------
# SESSIONS_WEB_DEV_PORT=5174
# SESSIONS_API_HOST=127.0.0.1
# SESSIONS_API_PORT=8787
# SESSIONS_CORS_ORIGINS=                 # extra allowed origins, comma-separated
# SESSIONS_CLAUDE_ROOT=~/.claude/projects
# SESSIONS_CODEX_ROOT=~/.codex/sessions
# SESSIONS_OPENCLAW_ROOT=~/.openclaw/agents
# SESSIONS_TRASH_DIR=                    # defaults to ~/.Trash on macOS, XDG trash on Linux
# SESSION_BOARD_ACTIVE_WINDOW=300

# --- openclaw --------------------------------------------------------------
# Fronts the local `openclaw` CLI (status, sessions, transcripts, live logs,
# chat). The backend shells out to the CLI, which owns the gateway auth token.
# OPENCLAW_WEB_DEV_PORT=5175
# OPENCLAW_WEB_DEV_HOST=127.0.0.1
# OPENCLAW_API_HOST=127.0.0.1  # keep loopback: this backend shells out to the openclaw CLI; exposing it exposes the agent
# OPENCLAW_API_PORT=8790
# OPENCLAW_BIN=                          # explicit path to the openclaw binary (else resolved on PATH)
# OPENCLAW_EXTRA_PATH=/opt/homebrew/bin:/usr/local/bin   # prepended to PATH so `openclaw` resolves under nx
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json         # gateway credentials are read for CLI child env only
# OPENCLAW_AGENTS_ROOT=~/.openclaw/agents
# OPENCLAW_CORS_ORIGINS=                 # extra allowed origins, comma-separated
# OPENCLAW_CHAT_TIMEOUT=120              # seconds; one agent turn can take a minute
# OPENCLAW_LOGS_MAX_BYTES=1000000        # CLI hard cap is 1000000

# --- model-diagram ---------------------------------------------------------
# FastAPI backend that drives a scoped Anthropic agent (SDK when
# ANTHROPIC_API_KEY is set, else the logged-in claude CLI) with read-only
# file tools to produce click-to-source model diagrams. The
# agent has NO web access; the only external material is the user's paper,
# fetched and parsed by the backend before the run.
# MODEL_DIAGRAM_WEB_DEV_PORT=5176
# MODEL_DIAGRAM_WEB_DEV_HOST=127.0.0.1
# MODEL_DIAGRAM_API_HOST=127.0.0.1        # keep loopback: the gateway supplies trusted identity
# MODEL_DIAGRAM_API_PORT=8791
# MODEL_DIAGRAM_DB=                       # defaults to $SSOT_DATA_DIR/model_diagram.db
# MODEL_DIAGRAM_PAPERS_DIR=               # defaults to $SSOT_DATA_DIR/model-diagram/papers
# MODEL_DIAGRAM_MODEL=claude-fable-5
# MODEL_DIAGRAM_PAPER_MAX_MB=30           # PDF size cap (spec: <=32MB / 600pp)
# MODEL_DIAGRAM_MAX_READ_BYTES=200000     # per read_file tool call
# MODEL_DIAGRAM_RUN_TIMEOUT_S=3600        # wall-clock ceiling per run (1h headroom for large repos)
# MODEL_DIAGRAM_CODEX_STAGE_MAX_BYTES=2147483648  # cap on the code/text mirrored for a codex run (2 GiB, post-exclusion)
# MODEL_DIAGRAM_STAGE_DIR=                 # where codex remote-root mirrors are staged (defaults under data dir)
# MODEL_DIAGRAM_STAGE_EXCLUDES=            # comma-separated extra tar globs to exclude from the mirror (weights/datasets already excluded)
# Anthropic credentials for the agent. Unset => runs error cleanly with
# error_kind=credentials_not_configured, surfaced in the UI.
# ANTHROPIC_API_KEY=
